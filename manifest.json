{
  "manifest_version": 3,
  "name": "YouTube Revenue Calculator | Crecaly",
  "version": "1.0",
  "description": "Calculate YouTube ad revenue per month. Factors in your specific RPM, global taxes, and audience geography instantly.",
  "homepage_url": "https://crecaly.com/", 
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@crecaly.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Calculate Revenue"
  },
  "icons": {
    "512" : "icon-512.png"
  }
}